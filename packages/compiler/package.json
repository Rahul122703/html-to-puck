{
  "name": "@html-to-puck/compiler",
  "version": "0.1.0",
  "description": "Convert static HTML into editable Puck components",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "watch": "tsup src/index.ts --watch --format esm,cjs --dts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "html",
    "puck",
    "compiler",
    "converter",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "hast": "^1.0.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "hast-util-to-text": "^4.0.2",
    "rehype-parse": "^9.0.1",
    "rehype-stringify": "^10.0.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.31.0",
    "prettier": "^3.9.6",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
